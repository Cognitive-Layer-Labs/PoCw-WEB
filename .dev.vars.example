# Copy to .dev.vars for local OpenNext + Wrangler preview.
# NEXTJS_ENV controls which Next.js .env files are loaded by OpenNext.
NEXTJS_ENV=development

# Server-only Oracle proxy configuration used by src/app/api/oracle/[...proxy]/route.ts
POCW_ORACLE_BASE_URL=http://localhost:3000
POCW_API_KEY=replace-with-shared-bearer-secret

# Public contract addresses for wallet chain routing
NEXT_PUBLIC_CONTROLLER_ADDRESS_31337=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
NEXT_PUBLIC_SBT_ADDRESS_31337=0x5FbDB2315678afecb367f032d93F642f64180aa3
NEXT_PUBLIC_CONTROLLER_ADDRESS_84532=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SBT_ADDRESS_84532=0x0000000000000000000000000000000000000000
